{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://YOUR_RENDER_API.onrender.com/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://YOUR_RENDER_API.onrender.com/socket.io/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
